##############################################################
### AUTHENTICATION ENDPOINTS
##############################################################

###
POST {{url}}/auth/register
Content-Type: application/json
Produces: application/json
x-correlation-id: {{x-correlation-id}}

{
  "name": "koewin Kohn",
  "email": "kohn1@example.com",
  "password": "SecurePass123!"
}


### 2. Login User
POST {{url}}/auth/login
Content-Type: application/json
Produces: application/json
x-correlation-id: {{x-correlation-id}}

{
  "email": "kohn@example.coms",
  "password": "NewSecurePass456!"
}

### 3. Logout (requires x-user-id header from login response)
POST {{url}}/auth/logout
x-correlation-id: {{x-correlation-id}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json
Produces: application/json

### 4. Refresh Token
POST {{url}}/auth/refresh
x-correlation-id: {{x-correlation-id}}
Authorization: Bearer {{refreshToken}}
Content-Type: application/json
Produces: application/json


### 5. Change Password
POST {{url}}/auth/change-password
x-correlation-id: {{x-correlation-id}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json
Produces: application/json

{
  "current_password": "NewSecurePass456!",
  "new_password": "AssPass456!",
  "confirm_password": "AssPass456"
}

##############################################################
### PROFILE MANAGEMENT ENDPOINTS
##############################################################

### 1. Create Profile
POST {{url}}/auth/profile
x-correlation-id: {{x-correlation-id}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Kohn Doe",
  "birthday": "1975-06-17",
  "weight": 50,
  "height": 180,
  "interests": ["coding", "music", "gaming"]
}

### 2. Get Profile
GET {{url}}/auth/profile
x-correlation-id: {{x-correlation-id}}
Authorization: Bearer {{accessToken}}


### 3. Update Profile
PUT {{url}}/auth/profile
x-correlation-id: {{x-correlation-id}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "weight": 78,
  "interests": ["coding", "music", "gaming", "traveling"]
}

##############################################################
### DOCUMENTATION ENDPOINTS
##############################################################

### View Swagger UI Documentation
GET {{url}}/docs

### Get OpenAPI Specification (JSON)
GET {{url}}/docs/openapi.json
